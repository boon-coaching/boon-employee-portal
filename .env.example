# Supabase Configuration
# Get these from your Supabase project settings > API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Preview mode (optional, for local development)
# VITE_PREVIEW_MODE=true
# VITE_PREVIEW_SECRET=your-preview-secret-here

# Welcome Survey URL (optional - defaults to https://boon.typeform.com/welcome)
# VITE_WELCOME_SURVEY_URL=https://boon.typeform.com/welcome

# IMPORTANT: Service role key must NOT have VITE_ prefix.
# It is only used by Edge Functions (server-side) and must never be bundled into client JS.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Note: Never commit .env.local with real values to git
# Copy this file to .env.local and fill in your actual values
